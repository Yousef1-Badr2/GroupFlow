rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: id, name, email, photoURL, phone, bio, isApproved, role, trialExpiresAt
    //
    // Collection: inviteCodes
    // Fields: id, code, used, usedBy, createdBy, createdAt, expiresAt, type
    //
    // Collection: projects
    // Fields: id, title, joinCode, leaderId, isArchived, createdAt, status
    //
    // Collection: projects/{projectId}/members
    // Fields: projectId, userId, role
    //
    // Collection: projects/{projectId}/tasks
    // Fields: id, projectId, description, dueDate, assignedTo, completed, completedBy
    //
    // [Other collections follow similar patterns]
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "yousef1mahmoud2@gmail.com" && request.auth.token.email_verified == true));
    }

    function isProjectMember(projectId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
    }

    function isProjectLeader(projectId) {
      return isAuthenticated() && get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role == 'leader';
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('email' in data) || data.email is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('isApproved' in data) || data.isApproved is bool) &&
             (!('role' in data) || data.role in ['admin', 'user']) &&
             (!('trialExpiresAt' in data) || data.trialExpiresAt is number);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'title', 'joinCode', 'leaderId', 'createdAt']) &&
             data.id is string && data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.joinCode is string && data.leaderId is string && data.createdAt is number;
    }

    function isValidMember(data) {
      return data.keys().hasAll(['projectId', 'userId', 'role']) &&
             data.projectId is string && data.userId is string &&
             data.role in ['leader', 'co-leader', 'member'];
    }

    function isValidInviteCode(data) {
      return data.keys().hasAll(['id', 'code', 'used', 'createdBy', 'createdAt', 'type']) &&
             data.id is string && data.code is string && data.used is bool &&
             data.createdBy is string && data.createdAt is number &&
             data.type in ['permanent', 'temporary'] &&
             (!('expiresAt' in data) || data.expiresAt is number) &&
             (!('usedBy' in data) || data.usedBy is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /inviteCodes/{codeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidInviteCode(request.resource.data);
      allow delete: if isAdmin();
      allow update: if (isAuthenticated() && 
                    resource.data.used == false && 
                    request.resource.data.used == true &&
                    request.resource.data.usedBy == request.auth.uid &&
                    isValidInviteCode(request.resource.data)) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) &&
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) &&
                    (isAdmin() || (isOwner(userId) && 
                                   request.resource.data.role == resource.data.role && 
                                   request.resource.data.isApproved == resource.data.isApproved));
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update, delete: if isProjectLeader(projectId) || isAdmin();

      match /members/{memberId} {
        allow read: if isProjectMember(projectId);
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidMember(request.resource.data);
        allow update: if isProjectLeader(projectId) || isAdmin() || (isOwner(memberId) && request.resource.data.role == resource.data.role);
        allow delete: if isProjectLeader(projectId) || isOwner(memberId) || isAdmin();
      }

      match /tasks/{taskId} {
        allow read: if isProjectMember(projectId);
        allow create, update, delete: if isProjectMember(projectId);
      }

      match /shoppingItems/{itemId} {
        allow read: if isProjectMember(projectId);
        allow create, update, delete: if isProjectMember(projectId);
      }

      match /polls/{pollId} {
        allow read: if isProjectMember(projectId);
        allow create, update, delete: if isProjectMember(projectId);
      }

      match /votes/{voteId} {
        allow read: if isProjectMember(projectId);
        allow create, update, delete: if isProjectMember(projectId);
      }

      match /messages/{messageId} {
        allow read: if isProjectMember(projectId);
        allow create: if isProjectMember(projectId);
      }

      match /expenses/{expenseId} {
        allow read: if isProjectMember(projectId);
        allow create, update, delete: if isProjectMember(projectId);
      }

      match /settlements/{settlementId} {
        allow read: if isProjectMember(projectId);
        allow create, update, delete: if isProjectMember(projectId);
      }
    }

    // Collection Group Rules for global listeners
    match /{path=**}/members/{memberId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isProjectMember(resource.data.projectId));
    }

    match /{path=**}/tasks/{taskId} {
      allow read: if isAuthenticated() && isProjectMember(resource.data.projectId);
    }

    match /{path=**}/shoppingItems/{itemId} {
      allow read: if isAuthenticated() && isProjectMember(resource.data.projectId);
    }

    match /{path=**}/polls/{pollId} {
      allow read: if isAuthenticated() && isProjectMember(resource.data.projectId);
    }

    match /{path=**}/votes/{voteId} {
      allow read: if isAuthenticated() && isProjectMember(resource.data.projectId);
    }

    match /{path=**}/messages/{messageId} {
      allow read: if isAuthenticated() && isProjectMember(resource.data.projectId);
    }

    match /{path=**}/expenses/{expenseId} {
      allow read: if isAuthenticated() && isProjectMember(resource.data.projectId);
    }

    match /{path=**}/settlements/{settlementId} {
      allow read: if isAuthenticated() && isProjectMember(resource.data.projectId);
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, update, delete: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
